# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local (já está no .gitignore).

# Connection string do Supabase.
# RECOMENDADO: use a do POOLER (Settings -> Database -> Connection pooling,
# modo "Transaction", porta 6543). Lembre de URL-encode no @ da senha (@ -> %40).
DATABASE_URL="postgresql://postgres.<project-ref>:<SENHA>@<host>.pooler.supabase.com:6543/postgres"

# Segredo para assinar o cookie de sessão. Gere algo aleatório e longo, ex.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="troque-por-uma-string-aleatoria-bem-longa"
